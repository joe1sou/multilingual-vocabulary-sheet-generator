# Server-only OpenRouter credential. Never prefix this variable with NEXT_PUBLIC_.
OPENROUTER_API_KEY=

# Model defaults. Both can be changed without editing application code.
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Emergency cost-control switch. Set to false to pause vocabulary and image generation.
GENERATION_ENABLED=true

# Public, build-time concurrency setting. Values are clamped to 1-4.
NEXT_PUBLIC_IMAGE_CONCURRENCY=4

# Used only for OpenRouter attribution headers.
NEXT_PUBLIC_APP_URL=http://localhost:3000
